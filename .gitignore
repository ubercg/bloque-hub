# =============================================================================
# BLOQUE Hub — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & Secrets (NUNCA commitear)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Python / Backend
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.venv/
venv/
env/
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
.tox/

# ---------------------------------------------------------------------------
# Node.js / Frontend
# ---------------------------------------------------------------------------
src/frontend/node_modules/
src/frontend/.next/
src/frontend/out/
src/frontend/.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json.bak

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.pid
*.sock

# ---------------------------------------------------------------------------
# Data & Storage (runtime files)
# ---------------------------------------------------------------------------
data/
storage/
*.db
*.sqlite
*.sqlite3

# ---------------------------------------------------------------------------
# IDE & Editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# OS & System
# ---------------------------------------------------------------------------
*.log
*.pid
*.tmp
*.temp

# ---------------------------------------------------------------------------
# Test results
# ---------------------------------------------------------------------------
src/frontend/test-results/
src/frontend/playwright-report/

# ---------------------------------------------------------------------------
# Build artifacts (backend Dockerfile uses COPY . .)
# ---------------------------------------------------------------------------
src/backend/dist/
src/backend/build/

# ---------------------------------------------------------------------------
# Development overrides
# ---------------------------------------------------------------------------
docker-compose.prod.yml
docker-compose.local.yml
