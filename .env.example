POSTGRES_USER=bloque
POSTGRES_PASSWORD=bloque_secret
POSTGRES_DB=bloque_hub
DATABASE_URL=postgresql://bloque:bloque_secret@db:5432/bloque_hub
APP_DATABASE_URL=postgresql://bloque:bloque_secret@db:5432/bloque_hub

# Frontend (Next): en build de Docker se pasa como build-arg (docker-compose.yml).
# Tras proxy con prefijo /bloque (ej. taskflow), descomentar:
# NEXT_PUBLIC_API_URL=/bloque/api
# Con nginx solo de bloque-hub (solo /api → backend): no definir (valor por defecto /api).
